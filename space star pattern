#include <stdio.h>
int main() {
    int i, j, spaces;
    int n;
    scanf("%d",&n);
    for (i = 1; i <= n; i++) {
        for (j = 1; j <= i; j++) {
            printf("%d", j);
        }
        for (spaces = 2; spaces <= 2 * (n - i); spaces++) {
            printf(" ");
        }
        for (j = i; j >= 1; j--) {
            if (j != n) {
                printf("%d",j);
            }
        }
        printf("\n");
    }
    return 0;
}

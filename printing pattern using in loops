#include <stdio.h>

int main() {
    int n;
    if (scanf("%d", &n) != 1) {
        return 1;
    }
    if (n == 0) {
        printf("0\n");
        return 0;
    }

    int size = 2 * n - 1;
    for (int i = 0; i < size; i++) {
        for (int j = 0; j < size; j++) {
            int min_dist = i < j ? i : j;
            min_dist = min_dist < size - 1 - i ? min_dist : size - 1 - i;
            min_dist = min_dist < size - 1 - j ? min_dist : size - 1 - j;
            int value = n - min_dist;
            printf("%d", value);
            if (j < size - 1) {
                printf(" ");
            }
        }
        printf("\n");
    }

    return 0;
}
